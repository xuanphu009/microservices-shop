{
  "info": {
    "name": "Lab2 Microservices",
    "_postman_id": "lab2-microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "description": "Product Service"
    },
    {
      "key": "order_url",
      "value": "http://localhost:3002",
      "description": "Order Service"
    },
    {
      "key": "auth_url",
      "value": "http://localhost:3003",
      "description": "Auth Service"
    },
    {
      "key": "gateway_url",
      "value": "http://localhost:3000",
      "description": "API Gateway"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT Access Token"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\",\"name\":\"Nguyễn Văn A\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\"}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{auth_url}}/api/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?page=1&limit=10",
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Products - Filter by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?category=mobile&inStock=true",
              "query": [
                {
                  "key": "category",
                  "value": "mobile"
                },
                {
                  "key": "inStock",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Get Products - Search + Price Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?search=iphone&minPrice=20000000&maxPrice=30000000",
              "query": []
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/1"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Samsung Galaxy A55\",\"price\":12990000,\"stock\":100,\"categoryId\":1,\"description\":\"Midrange flagship\"}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/products/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"price\":26990000,\"stock\":40}"
            }
          }
        },
        {
          "name": "Delete Product (Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/1"
          }
        },
        {
          "name": "POST - Invalid (422)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"\",\"price\":-100}"
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/categories",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Phụ kiện\",\"description\":\"Accessories\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{order_url}}/api/orders",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"customerId\":1,\"customerName\":\"Nguyễn Văn A\",\"customerEmail\":\"user@example.com\",\"items\":[{\"productId\":1,\"productName\":\"iPhone 15 Pro\",\"price\":27990000,\"quantity\":1}],\"shippingAddress\":{\"street\":\"123 Nguyễn Huệ\",\"district\":\"Q1\",\"city\":\"Hồ Chí Minh\"},\"note\":\"Giao hàng buổi sáng\"}"
            }
          }
        },
        {
          "name": "Get Orders by Customer",
          "request": {
            "method": "GET",
            "url": "{{order_url}}/api/orders/customer/1"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "url": "{{order_url}}/api/orders/ORDER_ID/status",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"confirmed\"}"
            }
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": "{{order_url}}/api/orders?status=pending"
          }
        }
      ]
    }
  ]
}