# =============================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git!
# =============================================

NODE_ENV=development

# ─── Product Service ──────────────────────
PRODUCT_SERVICE_PORT=3001
PRODUCT_DB_URL=postgresql://admin:secret@localhost:5432/products_db

# ─── Order Service ────────────────────────
ORDER_SERVICE_PORT=3002
MONGODB_URI=mongodb://admin:secret@localhost:27017/orders_db?authSource=admin

# ─── Auth Service ─────────────────────────
AUTH_SERVICE_PORT=3003
AUTH_DB_URL=postgresql://admin:secret@localhost:5432/auth_db
JWT_SECRET=your-super-secret-random-string-at-least-32-chars-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── API Gateway ──────────────────────────
GATEWAY_PORT=3000
PRODUCT_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
AUTH_SERVICE_URL=http://localhost:3003
ALLOWED_ORIGINS=http://localhost:3000

# ─── Production Overrides (Supabase/Atlas) ─
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PWD]@aws-...supabase.com:6543/postgres?pgbouncer=true
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxx.mongodb.net/ordersDB
